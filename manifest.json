{
  "manifest_version": 3,
  "name": "auto-translate",
  "description": "Translate supported web content, including X timelines and abc.com subtitles.",
  "version": "0.1.47",
  "permissions": ["storage", "contextMenus", "tabs", "scripting", "clipboardWrite"],
  "icons": {
    "16": "src/icons/icon16.png",
    "32": "src/icons/icon32.png",
    "48": "src/icons/icon48.png",
    "128": "src/icons/icon128.png"
  },
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://abc.com/*",
    "https://www.abc.com/*",
    "https://api.mymemory.translated.net/*",
    "https://libretranslate.com/*",
    "https://translate.googleapis.com/*",
    "https://*.media.dssott.com/*",
    "https://grok.com/*",
    "https://pbs.twimg.com/*",
    "https://*.twimg.com/*"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "action": {
    "default_title": "auto-translate",
    "default_icon": {
      "16": "src/icons/icon16.png",
      "32": "src/icons/icon32.png"
    },
    "default_popup": "src/popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://pan.baidu.com/*", "http://pan.baidu.com/*"],
      "js": ["src/pan-hide-ai-btn.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://abc.com/*", "https://www.abc.com/*"],
      "js": ["src/abc-subtitles.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/abc-page-hook.js"],
      "matches": ["https://abc.com/*", "https://www.abc.com/*"]
    }
  ]
}
